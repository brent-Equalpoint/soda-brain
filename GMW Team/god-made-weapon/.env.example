# .env.example
# God Made Weapon — Environment Variable Template
#
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real secret values.
# All secrets go in the secrets manager (AWS Secrets Manager or Doppler).
# Kennis Beck adds new variables here during implementation.
# Brianna Ops confirms all variables are set in each environment before deploying.
#
# Format:
# VARIABLE_NAME=example_value_or_description   # Owner: [Agent] | Purpose: [one line]

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NODE_ENV=development                            # Owner: Brianna Ops | Values: development, staging, production
PORT=3000                                       # Owner: Kennis Beck | Port the server runs on

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dbname   # Owner: Kennis Beck | PostgreSQL connection string

# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here                # Owner: Kennis Beck | Secret for signing JWT tokens
JWT_EXPIRY=7d                                  # Owner: Kennis Beck | Token expiry duration

# ─────────────────────────────────────────────
# Frontend (public — visible in browser)
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000      # Owner: Aniya Fronte | Base URL for API calls

# ─────────────────────────────────────────────
# Add new variables below this line
# Follow the format above: NAME=example  # Owner: [Agent] | Purpose: [description]
# ─────────────────────────────────────────────
