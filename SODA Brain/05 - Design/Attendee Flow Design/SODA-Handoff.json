  "screen_contracts": {
    "_shared": {
      "pattern": "{ screen|modal, state|variant, ...payload, primary, secondary }",
      "principle": "Server writes JSON, client renders. Server decides, client reflects.",
      "common_fields": ["state", "variant", "face_rule", "gated", "destination", "view.layout", "view.density"]
    },

    "home": {
      "screen": "home", "event_state": "live", "user_state": "returning",
      "hero": { "state": "live", "eyebrow": "Event live", "title": "Latinos-N-Tech is live right now.", "subtitle": "The room is open and {room_count} people are already in. Walk in as your card.", "cta": "Tap to enter", "cta_has_arrow": false, "action": { "type": "enter_room", "event_id": "evt_lnt_live" } },
      "cards": { "active_card_id": "founder", "editable_card_id": "founder", "face_rule": "me_face_has_no_chips", "items_ref": "data_model.me.cards" },
      "rooms_ref": "live room + past rooms", "connections_ref": "data_model.connections", "nav": { "active": "home", "items": ["home", "rooms", "card", "people", "you"] },
      "notes": "Hero eyebrow is GREEN. Headline white 26px. Button no arrow. Deck: highlighted = editable, swipe to switch."
    },

    "room": {
      "screen": "room",
      "context": { "event_id": "evt_lnt_live", "event_name": "Latinos-N-Tech", "room_live": true, "room_count": 19 },
      "view": { "layout": "grid", "density": "tabs", "rule": "grid_uses_tabs_list_uses_clean", "default_landing": "grid" },
      "grid_tabs": "each card: identity + offers_count + needs_count + match. corner dot if match.",
      "list_clean": "each row: identity + match.is_match ('Matches you'). No counts.",
      "tap_action": { "type": "open_card", "opens": "expand_payload" },
      "pill_action": { "type": "open_card_to_face", "faces": ["offers", "needs"] }
    },

    "card_expanded": {
      "modal": "card_expanded", "trigger": "open_card",
      "active_face": "me", "faces": ["offers", "me", "needs"], "face_rule": "me_face_has_no_chips",
      "offers_needs_ref": "person.offers / person.needs with {label, focus[]}",
      "match": { "is_match": true, "reason": "..." },
      "actions": [
        { "label": "Add connection", "action": "add_connection", "destination": "people", "added_label": "Added" },
        { "label": "Start an intro", "action": "open_intro_starter", "gated": true }
      ],
      "spacing_rule": "match-strip and action buttons each have padding; nothing touches."
    },

    "chip_detail": {
      "modal": "chip_detail", "trigger": "tap_or_hover_chip", "slides_from": "bottom",
      "kind": "offer | need", "label": "Mentorship", "focus": ["design"],
      "owner": "Maya", "owner_line": "{owner} offers this to the room | is looking for this",
      "no_focus_copy": "No focus added. Just {label}, broadly.",
      "actions": [ { "label": "Start an intro about this", "action": "open_intro_starter", "gated": true, "carries_chip_context": true }, { "label": "Close", "action": "dismiss" } ],
      "hover": "desktop lift + glow cue; tap opens sheet (mobile + desktop)"
    },

    "intro_starter": {
      "modal": "intro_starter", "trigger": "chip_tapped | card_action", "slides_from": "bottom",
      "target": { "id": "usr_maya", "name": "Maya", "context": "Founder, in the room now" },
      "based_on": { "kind": "offer", "label": "Mentorship", "focus": "design" },
      "openers": { "Warm": "...", "Simple": "...", "Direct": "..." }, "selected_tone": "Warm", "editable": true,
      "add_connection": { "offered": true, "default_on": true, "label": "Add to your connections", "destination": "people", "locks_on_if_already_connected": true },
      "primary": { "label": "Send intro", "action": "send_intro", "gated": true },
      "secondary": { "label": "Cancel", "action": "dismiss" },
      "trust_line": "SODA drafts it. You send it. Nothing goes out on its own.",
      "send_result": "intro_sent true; if add toggle on and not connected, connection_added true; toast 'Intro sent, {name} added to connections'"
    },

    "moment_event_left": {
      "modal": "event_left", "variant": "summary | quiet", "trigger": "user_left_room",
      "headline": { "value": "{connections_made}", "label": "connections made" },
      "people_strip": "first 4 avatars + overflow count",
      "body": "You walked in as {role} and left with {n} people worth knowing. They are warm now. Keep them that way.",
      "primary": { "label": "See my connections", "action": "open_people" },
      "secondary": { "label": "Back to {tab}", "action": "go_tab" },
      "zero_state": "No connections this time. Room still live, offer return.",
      "no_equalpoint_naming": true
    },

    "other_moment_modals_built": {
      "match": ["mutual", "complement"], "connection_count": ["milestone", "pace"], "top_connector": ["achieved (podium, is_you)", "missed (leaderboard + you + gap + progress)"],
      "note": "All carry gated flag on intro actions; gold for achievement; built in SODA-Moment-Modals(.html/-JSON.html)"
    },

    "condition_states_built": {
      "families": ["error (offline banner, server 500, action_failed inline, not_found)", "loading (skeleton, processing)", "decision (confirm_send, confirm_destructive, permission)", "locked (locked, closed/window_expired, countdown)", "restricted (wrong_role neutral, rate_limited, at_capacity)", "success (toast)"],
      "file": "SODA-Condition-States.html",
      "key": "wrong_role carries reveals_nothing:true + log_attempt:true (SODA-042 posture)"
    },

    "people": { "screen": "people", "framing": "Kept warm in SODA", "items_ref": "connections", "warmth_enum_ref": "design_tokens.warmth_enum" },
    "you": { "screen": "you", "stats": ["connections", "cards", "rooms"], "walking_in_as": "active card" },
    "nav": { "items": ["home", "rooms", "card", "people", "you"], "in_room_leaving_via_nav": "triggers event_left moment, then routes to chosen tab" }
  },

  "live_fire_flow": {
    "file": "SODA-Live-Fire.html",
    "happy_path": ["Home (live hero)", "Tap to enter -> Room", "grid Tabs / list Clean", "tap card -> full card", "flip faces (Me no chips)", "tap chip -> chip detail sheet", "Start an intro -> intro sheet (tones + add toggle, gated send)", "or Add connection on card", "leave via nav -> event_left moment", "See my connections -> People", "state persists to Home + You stat"],
    "state_persistence": "A connection added in room flows to: wrap-up count -> People -> Home Stay-warm -> You stat. One shared state object.",
    "known_tradeoffs": ["intro openers are templates not live AI (v1 ok)", "scroll-snap deck best on touch/trackpad"]
  },

  "deliverables_in_outputs": [
    "SODA-Live-Fire.html (the full interactive app)",
    "SODA-Home-JSON.html", "SODA-Room-MicroCards.html", "SODA-Room-JSON.html",
    "SODA-Intro-Starter-Mock.html", "SODA-Intro-Starter-JSON.html",
    "SODA-Moment-Modals.html", "SODA-Moment-Modals-JSON.html",
    "SODA-Condition-States.html", "SODA-Empty-States.html",
    "SODA-Card-Deck-Mock.html", "SODA-Home-Card-Deck.html", "SODA-Nav-Mock.html",
    "SODA-Recap-JSON.html", "SODA-Survey-Mock.html",
    "SODA-DECISIONS.md", "SODA-BUILD-CHECKLIST.md", "SODA-Risky-Ten-Best-Practices(.md/.docx)",
    "SODA-Ops-Manual-Gap-Analysis(.md/.docx)", "Equalpoint-Ops-Manual.md", "bank.ts (86 chips, 7 contexts)"
  ],

