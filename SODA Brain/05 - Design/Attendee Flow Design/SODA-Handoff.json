    "warmth_enum": {
      "in_rhythm": { "label": "In rhythm", "color": "#3bd75c" },
      "cooling": { "label": "Cooling", "color": "#f59e0b" },
      "been_a_while": { "label": "Been a while", "color": "#5a5a5a" }
