  "stack": {
    "frontend": "Next.js 16 App Router, React 19.2, Turbopack, PWA, Vercel",
    "backend": "Supabase (Postgres, RLS, Realtime, pg_cron)",
    "auth": "Clerk for attendee front door (SODA-038) via Supabase Third-Party Auth; host/ops on Supabase Auth",
    "email": "Resend", "errors": "Sentry", "ai": "claude-sonnet-4-6 for drafts",
    "state": "Zustand four-store (useEventStore, useAttendeeStore, useAuthStore, useOpsStore)",
    "rate_limiting": "Upstash", "ops_layer": "Airtable (one-way)",
    "secrets_conflict": "SODA-030 says Vercel env vars; ops manual says Doppler. UNRESOLVED, needs Brent."
