  "house_rules": {
    "no_em_dashes": true,
    "no_skinny_arrows_in_buttons": true,
    "no_it_is_not_x_it_is_y_contrast": true,
    "me_face_has_no_chips": "Me face is identity only (name + show_up + signature). Chips live on Offers and Needs faces.",
    "equalpoint_not_named_as_destination_yet": "Until Equalpoint platform is built, connections live in SODA People tab, kept warm. Add-connection destination = 'people'. Swap to 'equalpoint' later, one field.",
    "two_call_gate": "AI/intros: /api/draft generates, /api/draft/approve writes. Nothing sends without explicit confirm. Marked in contracts as gated:true.",
    "grid_uses_tabs_list_uses_clean": "Room: Grid layout shows Tabs pills (count Offers/Needs). List layout shows Clean rows (Matches you only). Layout drives density."
  },

  "design_tokens": {
    "mode": "dark only",
    "colors": {
      "canvas": "#111111", "card": "#1a1a1a", "surface": "#202220", "border": "#2a2a2a",
