    "dated": "2026-06-26",
    "company": { "product": "SODA", "engine": "Equalpoint", "pilot_client": "Futureland Inc.", "owner": "Alysha Ellis Montgomery (Future)", "cto": "Brent Montgomery", "lead_engineer": "Nelson Foster", "domain": "grabsoda.app" },
