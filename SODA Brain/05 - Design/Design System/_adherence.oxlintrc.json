{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/data-display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "screens/**",
              "ui_kits/admin/**",
              "ui_kits/attendee/**",
              "ui_kits/command-center/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo Black|DM Sans|DM Mono))/i]",
        "message": "Font not provided by the design system. Available: Archivo Black, DM Sans, DM Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|color|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|status|signal|dot|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, status, signal, dot, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|green|purple|amber|yellow|danger)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'green' | 'purple' | 'amber' | 'yellow' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:built|spec)$/]",
        "message": "<Badge> status must be one of 'built' | 'spec'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='signal'] > Literal[value!=/^(?:reached|nudge|saved|just)$/]",
        "message": "<Badge> signal must be one of 'reached' | 'nudge' | 'saved' | 'just'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomSheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|children|style|key|ref|className|style|children)$/]",
        "message": "<BottomSheet> doesn't accept that prop. Declared props: open, onClose, title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|disabled|icon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, disabled, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|purple|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'purple' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CarouselButtonArg'] > JSXAttribute > JSXIdentifier[name!=/^(?:last|next|label|key|ref|className|style|children)$/]",
        "message": "<CarouselButtonArg> doesn't accept that prop. Declared props: last, next, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|onClick|writeIn|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: selected, onClick, writeIn, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:length|value|onChange|error|key|ref|className|style|children)$/]",
        "message": "<CodeInput> doesn't accept that prop. Declared props: length, value, onChange, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|role|metAt|signal|warmthColor|src|onClick|boxed|style|key|ref|className|style|children)$/]",
        "message": "<ContactRow> doesn't accept that prop. Declared props: name, role, metAt, signal, warmthColor, src, onClick, boxed, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactRow'] > JSXAttribute[name.name='signal'] > Literal[value!=/^(?:reached|nudge|saved|just)$/]",
        "message": "<ContactRow> signal must be one of 'reached' | 'nudge' | 'saved' | 'just'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:host|name|date|where|met|recap|variant|onClick|key|ref|className|style|children)$/]",
        "message": "<EventCard> doesn't accept that prop. Declared props: host, name, date, where, met, recap, variant, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:strip|row)$/]",
        "message": "<EventCard> variant must be one of 'strip' | 'row'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:host|name|status|live|onClick|style|key|ref|className|style|children)$/]",
        "message": "<EventRow> doesn't accept that prop. Declared props: host, name, status, live, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|error|hint|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, error, hint."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|ratio|color|height|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, ratio, color, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResendControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:seconds|onResend|label|style|key|ref|className|style|children)$/]",
        "message": "<ResendControl> doesn't accept that prop. Declared props: seconds, onResend, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RolePill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<RolePill> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RolePill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:granted|owner|collaborator)$/]",
        "message": "<RolePill> tone must be one of 'granted' | 'owner' | 'collaborator'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|action|onAction|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: title, action, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|subtitle|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label, subtitle."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|color|style|key|ref|className|style|children)$/]",
        "message": "<StatTile> doesn't accept that prop. Declared props: value, label, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|icon|label|dot|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, icon, label, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:message|show|tone|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: message, show, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|purple|danger)$/]",
        "message": "<Toast> tone must be one of 'green' | 'purple' | 'danger'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
